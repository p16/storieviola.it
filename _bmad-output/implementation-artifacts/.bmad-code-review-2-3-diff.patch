diff --git a/storieviola-it/src/components/EpisodeCard.astro b/storieviola-it/src/components/EpisodeCard.astro
new file mode 100644
index 0000000..9c7e751
--- /dev/null
+++ b/storieviola-it/src/components/EpisodeCard.astro
@@ -0,0 +1,61 @@
+---
+/**
+ * Episode list item: row layout below md, card-style column from md (768px).
+ * One primary outbound link per episode (Spotify). Root is <li> with data-tags for Story 2.4.
+ */
+interface Props {
+  title: string;
+  description: string;
+  cover: string;
+  spotifyUrl: string;
+  tags: string[];
+}
+
+const { title, description, cover, spotifyUrl, tags } = Astro.props;
+
+const dataTags = tags.join(',');
+
+/** Match Hero.astro Spotify CTA focus (UX-DR10 / UX-DR11). */
+const focusCta =
+  'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-[#1DB954]';
+---
+
+<li
+  data-tags={dataTags}
+  class="flex flex-row gap-3 rounded-lg border border-gray-100 bg-white p-3 shadow-sm md:flex-col md:overflow-hidden md:p-0"
+>
+  <img
+    src={cover}
+    alt={title}
+    width="160"
+    height="160"
+    class="h-12 w-12 shrink-0 rounded-md object-cover md:h-40 md:w-full md:rounded-none md:rounded-t-lg"
+    loading="lazy"
+  />
+  <div class="flex min-w-0 flex-1 flex-col md:p-4">
+    <h3 class="text-base font-semibold text-gray-900">{title}</h3>
+    <p class="mt-1 line-clamp-2 text-sm text-gray-600 md:line-clamp-3">{description}</p>
+    {
+      tags.length > 0 && (
+        <div class="mt-2 flex flex-wrap gap-1.5" aria-label="Tag episodio">
+          {tags.map((tag) => (
+            <span class="rounded-full bg-violet-50 px-2 py-0.5 text-xs font-medium text-violet-800">
+              {tag}
+            </span>
+          ))}
+        </div>
+      )
+    }
+    <p class="mt-3 md:mt-auto md:pt-3">
+      <a
+        href={spotifyUrl}
+        class:list={[
+          'inline-flex min-h-11 min-w-[44px] items-center justify-center rounded-lg bg-[#1DB954] px-4 py-2 text-sm font-semibold text-white transition hover:bg-[#1ed760]',
+          focusCta,
+        ]}
+      >
+        Ascolta su Spotify
+      </a>
+    </p>
+  </div>
+</li>
