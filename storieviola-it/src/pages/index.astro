---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import EpisodeCard from '../components/EpisodeCard.astro';
import TagFilter from '../components/TagFilter.astro';
import { getCollection } from 'astro:content';
import { getSpotifyShowUrl } from '../lib/site';
import { sortEpisodesForPreview } from '../lib/sortEpisodes';

const allEpisodes = await getCollection('episodes');
const visibleEpisodes = allEpisodes.filter((ep) => !ep.data.hidden);
const sortedEpisodes = sortEpisodesForPreview(visibleEpisodes);

const podcastSpotifyUrl = getSpotifyShowUrl();

const normalizedTags = visibleEpisodes
  .flatMap((ep) => ep.data.tags ?? [])
  .map((t) => t.trim())
  .filter(Boolean)
  .map((t) => t.toLowerCase());

const uniqueTags = Array.from(new Set(normalizedTags))
  .filter((t) => t !== 'featured')
  .sort((a, b) => a.localeCompare(b));

const homepageDescription =
  'Storie originali per bambini, da ascoltare la sera, in viaggio o ogni volta che c\'è voglia di fantasia.';
---

<BaseLayout
  title="Storie Viola"
  description={homepageDescription}
  canonicalPath="/"
  ogImage="/images/og.png"
  ogImageAlt="Storie Viola — illustrazione del podcast di storie per bambini"
>
  <Hero
    imageSrc="/images/logo.png"
    imageAlt="Storie Viola — illustrazione del podcast di storie per bambini"
    title="Storie Viola"
    intro={homepageDescription}
    ctaHref={podcastSpotifyUrl}
    ctaLabel="Ascolta su Spotify"
  />

  <section class="mx-auto max-w-4xl px-4 pb-8 pt-2 md:pt-4" aria-labelledby="episodes-heading">
    <h2 id="episodes-heading" class="text-lg font-semibold text-foreground">
      Episodi
    </h2>
    {
      sortedEpisodes.length === 0 ? (
        <p class="mt-3 rounded-lg border border-dashed border-border bg-surface px-4 py-6 text-center text-sm text-muted">
          Nessun episodio ancora. Aggiungi un file in{' '}
          <code class="rounded bg-subtle px-1 py-0.5 text-code-text">src/content/episodes/</code> (vedi{' '}
          <code class="rounded bg-subtle px-1 py-0.5 text-code-text">CONTENT.md</code>).
        </p>
      ) : (
        <>
          <TagFilter
            tags={uniqueTags}
            initialTag="all"
          />

          <p
            data-episodes-empty
            hidden
            aria-live="polite"
            class="mt-3 rounded-lg border border-border bg-surface px-4 py-3 text-center text-sm text-muted"
          >
            Nessun episodio con questo tag. Seleziona{' '}
            <button
              type="button"
              data-clear-filter
              data-filter-button
              data-filter-tag="all"
              aria-pressed="false"
              class="inline-flex min-h-11 min-w-[44px] items-center justify-center rounded-lg border border-brand-300 bg-surface px-4 py-2 text-sm font-semibold text-brand-800 transition hover:bg-brand-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring-accent focus-visible:ring-offset-2"
            >
              Tutti
            </button>{' '}
            per vedere tutti gli episodi.
          </p>

          <ul
            data-episodes-list
            class="mt-3 space-y-3 md:grid md:grid-cols-2 md:gap-4 md:space-y-0"
          >
            {sortedEpisodes.map((episode) => (
              <EpisodeCard
                title={episode.data.title}
                description={episode.data.description}
                cover={episode.data.cover}
                spotifyUrl={episode.data.spotifyUrl}
                tags={episode.data.tags}
              />
            ))}
          </ul>

          <script>
            document.addEventListener('DOMContentLoaded', () => {
              const filterRoot = document.querySelector('[data-tag-filter]');
              if (!filterRoot) return;

              const buttons = Array.from(
                filterRoot.querySelectorAll('[data-filter-button]'),
              );
              const list = document.querySelector('[data-episodes-list]');
              const items = list
                ? Array.from(list.querySelectorAll('[data-tags]'))
                : [];
              const emptyState = document.querySelector('[data-episodes-empty]');
              const clearButton = emptyState?.querySelector(
                '[data-clear-filter]',
              );

              const selectedInitial =
                buttons.find((b) => b.getAttribute('aria-pressed') === 'true') ??
                buttons[0];
              let selectedTag = selectedInitial?.getAttribute('data-filter-tag') ?? 'all';

              function applyFilter(tag) {
                const tagLower = tag.toLowerCase();
                let matchCount = 0;

                items.forEach((li) => {
                  const dataTags = li.getAttribute('data-tags') ?? '';
                  const liTags = dataTags
                    .split(',')
                    .map((t) => t.trim().toLowerCase())
                    .filter(Boolean);

                  const matches = tagLower === 'all' ? true : liTags.includes(tagLower);
                  li.hidden = !matches;
                  if (matches) matchCount += 1;
                });

                if (emptyState) emptyState.hidden = matchCount > 0;
              }

              function setSelectedUi(nextTag) {
                buttons.forEach((btn) => {
                  const tag = btn.getAttribute('data-filter-tag') ?? 'all';
                  const active = tag.toLowerCase() === nextTag.toLowerCase();
                  btn.setAttribute('aria-pressed', active ? 'true' : 'false');

                  // Keep classes in sync with TagFilter.astro.
                  btn.classList.toggle('bg-brand-200', active);
                  btn.classList.toggle('border-brand-500', active);
                  btn.classList.toggle('text-brand-950', active);

                  btn.classList.toggle('bg-surface', !active);
                  btn.classList.toggle('border-brand-300', !active);
                  btn.classList.toggle('text-brand-800', !active);
                });

                // clearButton lives outside filterRoot, update it separately.
                if (clearButton) {
                  clearButton.setAttribute('aria-pressed', nextTag.toLowerCase() === 'all' ? 'true' : 'false');
                }
              }

              // Initial paint based on server-side `aria-pressed`.
              setSelectedUi(selectedTag);
              applyFilter(selectedTag);

              if (clearButton) {
                clearButton.addEventListener('click', () => {
                  selectedTag = 'all';
                  setSelectedUi(selectedTag);
                  applyFilter(selectedTag);
                });
              }

              buttons.forEach((btn) => {
                btn.addEventListener('click', () => {
                  const nextTag =
                    btn.getAttribute('data-filter-tag') ?? 'all';
                  selectedTag = nextTag;
                  setSelectedUi(selectedTag);
                  applyFilter(selectedTag);
                });
              });
            });
          </script>
        </>
      )
    }
  </section>
</BaseLayout>
