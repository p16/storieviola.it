---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import EpisodeCard from '../components/EpisodeCard.astro';
import { getCollection } from 'astro:content';
import { getSpotifyShowUrl } from '../lib/site';
import { sortEpisodesForPreview } from '../lib/sortEpisodes';

const allEpisodes = await getCollection('episodes');
const sortedEpisodes = sortEpisodesForPreview(allEpisodes);

const podcastSpotifyUrl = getSpotifyShowUrl();
---

<BaseLayout title="Storie Viola">
  <Hero
    imageSrc="/images/hero.svg"
    imageAlt="Storie Viola — illustrazione del podcast di storie per bambini"
    title="Storie Viola"
    intro="Storie per bambini da ascoltare in podcast: racconti pensati per la fantasia e la calma della sera."
    ctaHref={podcastSpotifyUrl}
    ctaLabel="Ascolta su Spotify"
  />

  <section class="mx-auto max-w-4xl px-4 pb-8 pt-4" aria-labelledby="episodes-heading">
    <h2 id="episodes-heading" class="text-lg font-semibold text-gray-900">
      Episodi
    </h2>
    {
      sortedEpisodes.length === 0 ? (
        <p class="mt-3 rounded-lg border border-dashed border-gray-300 bg-white px-4 py-6 text-center text-sm text-gray-600">
          Nessun episodio ancora. Aggiungi un file in{' '}
          <code class="rounded bg-gray-100 px-1 py-0.5 text-gray-800">src/content/episodes/</code> (vedi{' '}
          <code class="rounded bg-gray-100 px-1 py-0.5 text-gray-800">CONTENT.md</code>).
        </p>
      ) : (
        <ul class="mt-3 space-y-3 md:grid md:grid-cols-2 md:gap-4 md:space-y-0">
          {sortedEpisodes.map((episode) => (
            <EpisodeCard
              title={episode.data.title}
              description={episode.data.description}
              cover={episode.data.cover}
              spotifyUrl={episode.data.spotifyUrl}
              tags={episode.data.tags}
            />
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
