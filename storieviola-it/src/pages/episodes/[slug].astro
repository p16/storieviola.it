---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import LicenseNotice from '../../components/LicenseNotice.astro';

export async function getStaticPaths() {
  const episodes = await getCollection('episodes');
  return episodes.map((entry) => ({
    params: { slug: entry.data.slug },
  }));
}

const slug = Astro.params.slug ?? '';
const episodes = await getCollection('episodes');
const entry = episodes.find((episode) => episode.data.slug === slug);

if (!entry) {
  throw new Error(`Episode not found for slug "${slug}"`);
}

const { Content } = await render(entry);
---

<BaseLayout
  title={`${entry.data.title} | Storie Viola`}
  description={entry.data.description}
  canonicalPath={`/episodes/${entry.data.slug}`}
  ogImage={entry.data.cover}
  ogImageAlt={entry.data.title}
>
  <article class="mx-auto max-w-3xl px-4 py-8">
    <header class="space-y-4">
      <img
        src={entry.data.cover}
        alt={entry.data.title}
        width="1200"
        height="675"
        class="w-full rounded-lg border border-border object-cover"
      />
      <h1 class="text-3xl font-bold text-foreground">{entry.data.title}</h1>
      <p class="text-base text-muted">{entry.data.description}</p>
      {
        entry.data.spotifyUrl && (
          <p>
            <a
              href={entry.data.spotifyUrl}
              rel="noopener noreferrer"
              target="_blank"
              class="inline-flex min-h-11 min-w-[44px] items-center justify-center rounded-lg bg-cta px-4 py-2 text-sm font-semibold text-white transition hover:bg-cta-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-cta"
            >
              Ascolta su Spotify
            </a>
          </p>
        )
      }
    </header>

    <section class="prose prose-slate mt-8 max-w-none">
      <Content />
    </section>

    <footer class="mt-10">
      <LicenseNotice compact />
    </footer>
  </article>
</BaseLayout>
