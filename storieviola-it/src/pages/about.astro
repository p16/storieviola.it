---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const aboutEntries = await getCollection('about');
const aboutEntry = aboutEntries[0];
const { Content } = aboutEntry ? await render(aboutEntry) : { Content: null };
---

<BaseLayout
  title="About — Storie Viola"
  description="Scopri l'origine di Storie Viola e come ogni episodio è pensato per un ascolto calmo e pieno di fantasia."
  canonicalPath="/about"
  ogImage="/images/og.png"
  ogImageAlt="Storie Viola — illustrazione del podcast di storie per bambini"
>
  <div class="mx-auto max-w-3xl px-4 py-8">
    {Content ? <Content /> : <p>About content not found.</p>}
  </div>
</BaseLayout>
