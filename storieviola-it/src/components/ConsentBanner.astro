---
---

<div
  id="consent-banner"
  hidden
  lang="it"
  role="region"
  aria-live="polite"
  aria-label="Consenso sui cookie e analytics"
  class="fixed bottom-0 left-0 right-0 z-50 border-t border-border bg-surface p-4 shadow-lg md:p-5"
>
  <div
    class="mx-auto flex max-w-4xl flex-col gap-4 md:flex-row md:items-center md:justify-between"
  >
    <p class="text-sm text-muted-strong">
      Usiamo Google Analytics solo con il tuo consenso, per capire come viene usato il
      sito. I dati sono aggregati.
    </p>
    <div class="flex flex-wrap gap-2">
      <button
        type="button"
        id="consent-accept"
        class="inline-flex min-h-11 min-w-[44px] items-center justify-center rounded-lg bg-brand-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring-accent focus-visible:ring-offset-2"
      >
        Accetta analytics
      </button>
      <button
        type="button"
        id="consent-reject"
        class="inline-flex min-h-11 min-w-[44px] items-center justify-center rounded-lg border border-border bg-surface px-4 py-2 text-sm font-semibold text-foreground transition hover:bg-subtle focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring-accent focus-visible:ring-offset-2"
      >
        Rifiuta
      </button>
    </div>
  </div>
</div>
