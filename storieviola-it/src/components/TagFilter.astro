---
interface Props {
  tags: string[];
  /** Initial selection key used only for server-side first paint. */
  initialTag: string;
}

const { tags, initialTag } = Astro.props;
import { getTagFilterButtonClass } from '../lib/tagFilterStyles';
---

<div data-tag-filter aria-label="Filtra episodi per tag" class="mt-3 md:mt-4">
  <div class="flex flex-wrap gap-2">
    <button
      type="button"
      data-filter-button
      data-filter-tag="all"
      aria-pressed={initialTag === 'all' ? 'true' : 'false'}
      class={getTagFilterButtonClass(initialTag === 'all')}
    >
      Tutti
    </button>

    {tags.map((tag) => (
      <button
        type="button"
        data-filter-button
        data-filter-tag={tag}
        aria-pressed={initialTag === tag ? 'true' : 'false'}
        class={getTagFilterButtonClass(initialTag === tag)}
        key={tag}
      >
        {tag}
      </button>
    ))}
  </div>
</div>
