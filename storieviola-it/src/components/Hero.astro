---
import { focusCta } from '../lib/focusStyles';

/**
 * Compact hero: Direction C (stacked, centred) by default; Direction B (horizontal bar) from md (768px).
 * Single <h1> for the podcast title; optional one podcast-level CTA.
 */
interface Props {
  imageSrc: string;
  imageAlt: string;
  title: string;
  intro: string;
  /** Optional podcast-level CTA (e.g. Spotify show link) */
  ctaHref?: string;
  ctaLabel?: string;
}

const { imageSrc, imageAlt, title, intro, ctaHref, ctaLabel } = Astro.props;
---

<section class="border-b border-border bg-surface" aria-labelledby="hero-title">
  <div
    class="mx-auto flex max-w-4xl flex-col items-center gap-3 px-4 py-3 text-center md:flex-row md:items-center md:gap-6 md:py-5 md:text-left"
  >
    <img
      src={imageSrc}
      alt={imageAlt}
      width="96"
      height="96"
      class="h-20 w-20 shrink-0 rounded-2xl object-cover shadow-sm md:h-24 md:w-24"
      loading="eager"
      fetchpriority="high"
    />
    <div class="min-w-0 flex-1">
      <h1
        id="hero-title"
        class="text-[length:var(--font-size-display)] font-bold tracking-tight text-foreground md:text-[length:var(--font-size-display-md)]"
      >
        {title}
      </h1>
      <p class="mt-2 text-pretty text-base text-muted md:text-[length:var(--font-size-lead)]">
        {intro}
      </p>
      {
        ctaHref && ctaLabel && (
          <p class="mt-3">
            <a
              href={ctaHref}
              rel="noopener noreferrer"
              target="_blank"
              class:list={[
                'inline-flex min-h-11 min-w-[44px] items-center justify-center rounded-lg bg-cta px-4 py-2 text-sm font-semibold text-white transition hover:bg-cta-hover',
                focusCta,
              ]}
            >
              {ctaLabel}
            </a>
          </p>
        )
      }
    </div>
  </div>
</section>
