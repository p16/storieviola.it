---
import { focusCta, focusPrimaryCta, focusTextLink } from '../lib/focusStyles';

/**
 * Episode list item: row layout below md, card-style column from md (768px).
 * Slightly tighter cover/padding from xl so four-column grid stays readable (Story 8.1).
 * Episode navigation: linked title + full-width "Leggi la storia"; cover is decorative (alt="").
 * Optional "Ascolta su Spotify" when `spotifyUrl` is set.
 * Root is <li> with data-tags for Story 2.4.
 */
interface Props {
  title: string;
  slug: string;
  description: string;
  cover: string;
  spotifyUrl?: string;
  tags: string[];
}

const { title, slug, description, cover, spotifyUrl, tags } = Astro.props;
import { normalizeTags } from '../lib/tagFiltering';

// Normalize tag values so `data-tags` remains stable for filtering (e.g. remove accidental whitespace).
const normalizedTags = normalizeTags(tags);
const tagsString = normalizedTags.join(',');
---

<li
  data-tags={tagsString}
  class="flex flex-row gap-3 rounded-lg border border-border-subtle bg-surface p-3 shadow-sm md:flex-col md:overflow-hidden md:p-0"
>
  <div
    class="shrink-0 overflow-hidden rounded-md md:w-full md:rounded-none md:rounded-t-lg"
    aria-hidden="true"
  >
    <img
      src={cover}
      alt=""
      width="160"
      height="160"
      class="h-12 w-12 object-cover md:h-40 md:w-full xl:h-36"
      loading="lazy"
    />
  </div>
  <div class="flex min-w-0 flex-1 flex-col md:p-4 xl:p-3">
    <h3 class="text-base font-semibold text-foreground">
      <a
        href={`/episodes/${slug}`}
        class:list={['rounded-sm transition hover:text-brand-700', focusTextLink]}
      >
        {title}
      </a>
    </h3>
    <p class="mt-1 line-clamp-2 text-sm text-muted md:line-clamp-3">{description}</p>
    {
      normalizedTags.length > 0 && (
        <ul
          class="mt-2 flex flex-wrap gap-1.5"
          aria-label="Tag episodio"
          role="list"
        >
          {normalizedTags.map((tag, idx) => (
            <li
              key={`${tag}-${idx}`}
              class="rounded-full bg-brand-50 px-2 py-0.5 text-xs font-medium text-brand-800"
              role="listitem"
            >
              {tag}
            </li>
          ))}
        </ul>
      )
    }
    <div class="mt-3 md:mt-auto md:pt-3 flex w-full min-w-0 flex-col gap-3">
      <a
        href={`/episodes/${slug}`}
        class:list={[
          'inline-flex min-h-11 w-full min-w-0 items-center justify-center rounded-xl border border-brand-300 bg-surface px-4 py-2.5 text-sm font-semibold text-brand-800 transition hover:bg-brand-50',
          focusPrimaryCta,
        ]}
      >
        Leggi la storia
      </a>
      {
        spotifyUrl && (
          <a
            href={spotifyUrl}
            rel="noopener noreferrer"
            target="_blank"
            aria-label={`Ascolta su Spotify: ${title}`}
            class:list={[
              'inline-flex min-h-11 w-full min-w-0 items-center justify-center rounded-xl bg-cta px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-cta-hover',
              focusCta,
            ]}
          >
            Ascolta su Spotify
          </a>
        )
      }
    </div>
  </div>
</li>
