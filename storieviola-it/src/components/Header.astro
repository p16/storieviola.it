---
// Header: site identity (link to home) + link to About. Semantic <header> and <nav>; visible focus styles (UX-DR2).
const homeFocus =
  'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2';
const navFocus =
  'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2';
---

<header class="border-b border-border bg-surface">
  <nav class="mx-auto flex max-w-4xl items-center gap-6 px-4 py-3" aria-label="Main">
    <a
      href="/"
      class:list={[
        'inline-flex max-w-[min(100%,20rem)] items-center gap-2 rounded-md text-lg font-semibold text-foreground',
        homeFocus,
      ]}
    >
      <img
        src="/images/logo.png"
        alt=""
        width="144"
        height="144"
        class="h-8 w-auto max-h-9 max-w-[10rem] shrink-0 object-contain md:h-9"
        aria-hidden="true"
        loading="eager"
        decoding="async"
      />
      <span>Storie Viola</span>
    </a>
    <a
      href="/about"
      class:list={['text-muted transition hover:text-foreground', navFocus]}
    >
      About
    </a>
  </nav>
</header>
