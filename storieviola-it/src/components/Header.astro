---
// Header: site identity (link to home) + link to About. Semantic <header> and <nav>; visible focus styles (UX-DR2).
---

<header class="border-b border-gray-200 bg-white">
  <nav class="mx-auto flex max-w-4xl items-center gap-6 px-4 py-3" aria-label="Main">
    <a
      href="/"
      class="text-lg font-semibold text-gray-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-900 focus-visible:ring-offset-2"
    >
      Storie Viola
    </a>
    <a
      href="/about"
      class="text-gray-600 hover:text-gray-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-900 focus-visible:ring-offset-2"
    >
      About
    </a>
  </nav>
</header>
